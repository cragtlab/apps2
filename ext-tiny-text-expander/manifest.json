{
  "manifest_version": 3,
  "name": "Tiny Text Expander",
  "version": "1.0.0",
  "description": "Ultra-minimal web text expander with sync.",
  "permissions": [
    "storage"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}